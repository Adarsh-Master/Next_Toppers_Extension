{
  "manifest_version": 3,
  "name": "NextToppers Pro Plus",
  "version": "6.7",
  "description": "Modern UI assistant: Unlocks playback features, shortcuts, auto-polls, and spam controls.",
  "permissions": ["tabs", "scripting"],
  "host_permissions": ["<all_urls>"],

  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://nexttoppers.com/private/myProfile/play/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
